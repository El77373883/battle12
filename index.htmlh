<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, maximum-scale=1.0, minimum-scale=1.0, shrink-to-fit=no, viewport-fit=cover">
  <title>⚔️ BATTLE ROYALE - LOBBY 3D</title>
  <style>
    body {
      margin: 0;
      overflow: hidden;
      font-family: 'Segoe UI', 'Arial', sans-serif;
      background: #000;
      touch-action: pan-x pan-y pinch-zoom; 
    }
    #info {
      position: absolute;
      top: 20px;
      left: 20px;
      color: white;
      background: rgba(0,0,0,0.7);
      padding: 10px 20px;
      border-radius: 10px;
      pointer-events: none;
      backdrop-filter: blur(5px);
      font-weight: bold;
      letter-spacing: 1px;
      display: none;
      z-index: 10;
    }
    #lobby-container, #waiting-container {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: center;
      pointer-events: none;
      z-index: 20;
    }
    .lobby-panel {
      background: rgba(20, 20, 30, 0.85);
      backdrop-filter: blur(20px);
      border-radius: 40px 40px 0 0;
      padding: 30px 20px 40px;
      width: 90%;
      max-width: 500px;
      color: white;
      box-shadow: 0 -10px 40px rgba(0,0,0,0.8);
      text-align: center;
      border-top: 2px solid rgba(255, 215, 0, 0.7);
      pointer-events: auto;
      animation: slideUp 0.5s ease-out;
    }
    @keyframes slideUp {
      from { transform: translateY(100%); }
      to { transform: translateY(0); }
    }
    .lobby-title {
      font-size: 2.5rem;
      font-weight: 900;
      color: #ffd966;
      text-shadow: 0 0 20px #ffaa00;
      margin: 0 0 10px;
      letter-spacing: 3px;
    }
    .character-preview {
      margin: 20px auto;
      font-size: 1.2rem;
      background: rgba(0,0,0,0.5);
      padding: 15px;
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 15px;
      flex-wrap: wrap;
    }
    .gold-btn {
      background: linear-gradient(45deg, #ffd700, #ffaa00);
      border: none;
      color: black;
      font-weight: bold;
      font-size: 1.5rem;
      padding: 15px 40px;
      border-radius: 50px;
      letter-spacing: 2px;
      cursor: pointer;
      box-shadow: 0 8px 20px rgba(255,200,0,0.6);
      transition: all 0.3s;
      margin: 10px 0;
      width: 100%;
      text-transform: uppercase;
      border: 2px solid white;
    }
    .gold-btn:active {
      transform: scale(0.95);
      box-shadow: 0 4px 10px rgba(255,200,0,0.8);
    }
    .store-btn {
      background: rgba(255,255,255,0.15);
      border: 1px solid rgba(255,255,255,0.4);
      color: white;
      font-weight: bold;
      padding: 12px 25px;
      border-radius: 30px;
      margin: 5px;
      cursor: pointer;
      backdrop-filter: blur(10px);
      transition: 0.2s;
    }
    .store-btn:hover {
      background: rgba(255,255,255,0.3);
    }
    .players-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 8px;
      margin: 15px 0;
      max-height: 120px;
      overflow-y: auto;
      padding: 5px;
    }
    .player-dot {
      background: #4caf50;
      border-radius: 50%;
      width: 20px;
      height: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      color: white;
      box-shadow: 0 0 10px #4caf50;
    }
    .timer {
      font-size: 3rem;
      font-weight: 900;
      color: #ffaa00;
      text-shadow: 0 0 20px red;
    }
    #crosshair {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: rgba(255,255,255,0.9);
      font-size: 28px;
      pointer-events: none;
      z-index: 30;
      display: none;
      text-shadow: 0 0 10px black;
    }
    #minimap {
      position: absolute;
      bottom: 20px;
      right: 20px;
      width: 130px;
      height: 130px;
      background: rgba(0,0,0,0.6);
      border-radius: 50%;
      border: 3px solid white;
      backdrop-filter: blur(8px);
      z-index: 25;
      display: none;
      overflow: hidden;
      box-shadow: 0 0 20px rgba(0,0,0,0.7);
    }
    #plane-indicator {
      position: absolute;
      top: 20px;
      right: 20px;
      background: rgba(0,0,0,0.7);
      color: gold;
      padding: 5px 15px;
      border-radius: 20px;
      display: none;
      z-index: 25;
      font-weight: bold;
    }
    @media (max-width: 600px) {
      .lobby-title { font-size: 1.8rem; }
    }
  </style>
</head>
<body>
  <div id="info">🎯 Jugador en lobby</div>
  <div id="crosshair">✚</div>
  <div id="plane-indicator">✈️ AVION - Presiona ESPACIO para saltar</div>
  <div id="minimap"><canvas id="minimap-canvas" width="130" height="130" style="width:100%;height:100%;"></canvas></div>

  <div id="lobby-container">
    <div class="lobby-panel" id="lobby-panel">
      <div class="lobby-title">⚡BATTLE ROYALE</div>
      <div class="character-preview">
        <span>🔥</span> <span id="skin-name">SKIN ÉPICA</span> <span>🔥</span>
      </div>
      <div style="display:flex; gap:10px; justify-content:center; margin-bottom:10px;">
        <button class="store-btn" id="lucky-royale">🎰 LUCKY ROYALE</button>
        <button class="store-btn" id="tienda-btn">🛒 TIENDA</button>
      </div>
      <button class="gold-btn" id="start-game-btn">▶ INICIAR PARTIDA</button>
      <div style="color:#aaa; margin-top:10px;">50 jugadores • Battle Royale</div>
    </div>
  </div>

  <div id="waiting-container" style="display: none;">
    <div class="lobby-panel" style="border-radius:40px;">
      <div class="lobby-title">⏳ SALA DE ESPERA</div>
      <div class="players-grid" id="waiting-players"></div>
      <div class="timer" id="waiting-timer">30</div>
      <div style="color:white;">Jugadores listos: <span id="player-count">50</span>/50</div>
      <button class="store-btn" id="cancel-waiting" style="margin-top:15px;">CANCELAR</button>
    </div>
  </div>

  <script type="importmap">
    {
      "imports": {
        "three": "https://unpkg.com/three@0.128.0/build/three.module.js",
        "three/addons/": "https://unpkg.com/three@0.128.0/examples/jsm/"
      }
    }
  </script>

  <script type="module">
    import * as THREE from 'three';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
    import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';

    // ---------- ESTADO DEL JUEGO ----------
    const State = {
      LOBBY: 'LOBBY',
      WAITING: 'WAITING',
      PLANE: 'PLANE',
      PLAYING: 'PLAYING'
    };
    let currentState = State.LOBBY;
    
    // Configuración
    const TOTAL_PLAYERS = 50;
    const WAIT_SECONDS = 30;
    
    // Variables globales
    let scene, camera, renderer, labelRenderer;
    let playerModel, lobbyCharacter;
    let plane, planeGroup;
    let waitingPlayersElements = [];
    let countdownInterval;
    let gamePlayers = [];
    let localPlayer = {
      position: new THREE.Vector3(0, 5, 0),
      velocity: new THREE.Vector3(0, 0, 0),
      inPlane: false,
      hasParachute: false,
      onGround: false
    };
    
    // Controles
    let keys = { w: false, a: false, s: false, d: false, space: false };
    let moveDirection = new THREE.Vector3();
    let cameraYaw = 0, cameraPitch = 0;
    
    // Elementos UI
    const lobbyContainer = document.getElementById('lobby-container');
    const waitingContainer = document.getElementById('waiting-container');
    const crosshair = document.getElementById('crosshair');
    const planeIndicator = document.getElementById('plane-indicator');
    const minimap = document.getElementById('minimap');
    const minimapCanvas = document.getElementById('minimap-canvas');
    const ctxMinimap = minimapCanvas.getContext('2d');
    
    // Mundo
    let ground, mountains = [], houses = [], trees = [], cars = [], weapons = [];

    // ---------- INICIALIZACIÓN THREE.JS ----------
    function initThree() {
      scene = new THREE.Scene();
      scene.background = new THREE.Color(0x1a1a2e);
      scene.fog = new THREE.Fog(0x1a1a2e, 50, 300);
      
      camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.5, 500);
      camera.position.set(0, 8, 15);
      
      renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.shadowMap.enabled = true;
      renderer.shadowMap.type = THREE.PCFSoftShadowMap;
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      document.body.appendChild(renderer.domElement);
      
      labelRenderer = new CSS2DRenderer();
      labelRenderer.setSize(window.innerWidth, window.innerHeight);
      labelRenderer.domElement.style.position = 'absolute';
      labelRenderer.domElement.style.top = '0px';
      labelRenderer.domElement.style.left = '0px';
      labelRenderer.domElement.style.pointerEvents = 'none';
      document.body.appendChild(labelRenderer.domElement);
      
      // Luces
      const ambient = new THREE.AmbientLight(0x404066);
      scene.add(ambient);
      const sun = new THREE.DirectionalLight(0xffeedd, 1.2);
      sun.position.set(100, 80, 40);
      sun.castShadow = true;
      sun.receiveShadow = true;
      sun.shadow.mapSize.width = 1024;
      sun.shadow.mapSize.height = 1024;
      sun.shadow.camera.near = 1;
      sun.shadow.camera.far = 300;
      sun.shadow.camera.left = -80;
      sun.shadow.camera.right = 80;
      sun.shadow.camera.top = 80;
      sun.shadow.camera.bottom = -80;
      scene.add(sun);
      
      window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
        labelRenderer.setSize(window.innerWidth, window.innerHeight);
      });
    }

    // Crear personaje estilizado (No tieso, con animaciones)
    function createCharacter(color = 0xff5500, isLocal = false) {
      const group = new THREE.Group();
      
      // Cuerpo con forma más detallada
      const bodyGeo = new THREE.CylinderGeometry(0.45, 0.5, 1.8, 8);
      const bodyMat = new THREE.MeshStandardMaterial({ color: 0x222244, roughness: 0.4 });
      const body = new THREE.Mesh(bodyGeo, bodyMat);
      body.castShadow = true;
      body.receiveShadow = true;
      body.position.y = 0.9;
      group.add(body);
      
      // Armadura/Chaleco
      const vestGeo = new THREE.CylinderGeometry(0.5, 0.55, 1.2, 8);
      const vestMat = new THREE.MeshStandardMaterial({ color: color, roughness: 0.3, emissive: new THREE.Color(0x331100) });
      const vest = new THREE.Mesh(vestGeo, vestMat);
      vest.castShadow = true;
      vest.receiveShadow = true;
      vest.position.y = 1.0;
      group.add(vest);
      
      // Cabeza
      const headGeo = new THREE.SphereGeometry(0.45, 16, 16);
      const headMat = new THREE.MeshStandardMaterial({ color: 0xffccaa, roughness: 0.2 });
      const head = new THREE.Mesh(headGeo, headMat);
      head.castShadow = true;
      head.receiveShadow = true;
      head.position.y = 1.9;
      group.add(head);
      
      // Casco
      const helmetGeo = new THREE.SphereGeometry(0.48, 16, 16);
      const helmetMat = new THREE.MeshStandardMaterial({ color: 0x333333, roughness: 0.1, metalness: 0.8 });
      const helmet = new THREE.Mesh(helmetGeo, helmetMat);
      helmet.castShadow = true;
      helmet.receiveShadow = true;
      helmet.position.y = 2.0;
      group.add(helmet);
      
      // Brazos
      const armGeo = new THREE.CylinderGeometry(0.15, 0.18, 0.9, 6);
      const armMat = new THREE.MeshStandardMaterial({ color: 0x222244 });
      const leftArm = new THREE.Mesh(armGeo, armMat);
      leftArm.position.set(-0.6, 1.4, 0);
      leftArm.rotation.z = 0.2;
      leftArm.rotation.x = 0.1;
      leftArm.castShadow = true;
      group.add(leftArm);
      
      const rightArm = new THREE.Mesh(armGeo, armMat);
      rightArm.position.set(0.6, 1.4, 0);
      rightArm.rotation.z = -0.2;
      rightArm.rotation.x = -0.1;
      rightArm.castShadow = true;
      group.add(rightArm);
      
      // Piernas
      const legGeo = new THREE.CylinderGeometry(0.2, 0.22, 0.9, 6);
      const legMat = new THREE.MeshStandardMaterial({ color: 0x1a1a2e });
      const leftLeg = new THREE.Mesh(legGeo, legMat);
      leftLeg.position.set(-0.3, 0.4, 0);
      leftLeg.castShadow = true;
      group.add(leftLeg);
      
      const rightLeg = new THREE.Mesh(legGeo, legMat);
      rightLeg.position.set(0.3, 0.4, 0);
      rightLeg.castShadow = true;
      group.add(rightLeg);
      
      // Arma en espalda
      const gunGroup = new THREE.Group();
      const barrel = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.08, 0.7, 6), new THREE.MeshStandardMaterial({ color: 0x111111 }));
      barrel.rotation.x = Math.PI/2;
      barrel.position.z = 0.4;
      gunGroup.add(barrel);
      gunGroup.position.set(0.5, 1.6, -0.3);
      gunGroup.rotation.y = 0.3;
      group.add(gunGroup);
      
      return group;
    }

    function createWorld() {
      // Suelo
      const groundGeo = new THREE.CircleGeometry(120, 64);
      const groundMat = new THREE.MeshStandardMaterial({ color: 0x3a5a3a, roughness: 0.9 });
      ground = new THREE.Mesh(groundGeo, groundMat);
      ground.rotation.x = -Math.PI/2;
      ground.position.y = -0.1;
      ground.receiveShadow = true;
      scene.add(ground);
      
      // Montañas
      for (let i = 0; i < 15; i++) {
        const angle = (i / 15) * Math.PI * 2;
        const radius = 50 + Math.random() * 40;
        const x = Math.cos(angle) * radius;
        const z = Math.sin(angle) * radius;
        const height = 5 + Math.random() * 15;
        const mountainGeo = new THREE.ConeGeometry(4 + Math.random() * 6, height, 8);
        const mountain = new THREE.Mesh(mountainGeo, new THREE.MeshStandardMaterial({ color: 0x4a6741, roughness: 0.7 }));
        mountain.position.set(x, height/2 - 0.1, z);
        mountain.castShadow = true;
        mountain.receiveShadow = true;
        scene.add(mountain);
        mountains.push(mountain);
      }
      
      // Casas
      for (let i = 0; i < 12; i++) {
        const angle = Math.random() * Math.PI * 2;
        const dist = 20 + Math.random() * 50;
        const x = Math.cos(angle) * dist;
        const z = Math.sin(angle) * dist;
        const houseGroup = new THREE.Group();
        const wall = new THREE.Mesh(new THREE.BoxGeometry(2.5, 2.2, 2.5), new THREE.MeshStandardMaterial({ color: 0xccbbaa }));
        wall.position.y = 1.1;
        wall.castShadow = true; wall.receiveShadow = true;
        houseGroup.add(wall);
        const roof = new THREE.Mesh(new THREE.ConeGeometry(1.8, 1.2, 4), new THREE.MeshStandardMaterial({ color: 0x993333 }));
        roof.position.y = 2.2;
        roof.castShadow = true;
        houseGroup.add(roof);
        houseGroup.position.set(x, 0, z);
        scene.add(houseGroup);
        houses.push(houseGroup);
      }
      
      // Árboles
      for (let i = 0; i < 60; i++) {
        const angle = Math.random() * Math.PI*2;
        const dist = 8 + Math.random() * 70;
        const x = Math.cos(angle) * dist;
        const z = Math.sin(angle) * dist;
        const treeGroup = new THREE.Group();
        const trunk = new THREE.Mesh(new THREE.CylinderGeometry(0.3, 0.4, 2), new THREE.MeshStandardMaterial({ color: 0x8b5a2b }));
        trunk.position.y = 1;
        trunk.castShadow = true; trunk.receiveShadow = true;
        treeGroup.add(trunk);
        const foliage = new THREE.Mesh(new THREE.ConeGeometry(1.2, 2.5, 8), new THREE.MeshStandardMaterial({ color: 0x2d5a27 }));
        foliage.position.y = 2.5;
        foliage.castShadow = true;
        treeGroup.add(foliage);
        treeGroup.position.set(x, 0, z);
        scene.add(treeGroup);
        trees.push(treeGroup);
      }
      
      // Carros
      for (let i = 0; i < 8; i++) {
        const angle = Math.random() * Math.PI*2;
        const dist = 15 + Math.random() * 45;
        const x = Math.cos(angle) * dist;
        const z = Math.sin(angle) * dist;
        const carGroup = new THREE.Group();
        const body = new THREE.Mesh(new THREE.BoxGeometry(1.8, 0.6, 3.2), new THREE.MeshStandardMaterial({ color: 0x2244aa }));
        body.position.y = 0.5;
        body.castShadow = true; body.receiveShadow = true;
        carGroup.add(body);
        const cabin = new THREE.Mesh(new THREE.BoxGeometry(1.4, 0.5, 1.8), new THREE.MeshStandardMaterial({ color: 0x88aacc }));
        cabin.position.set(0, 0.9, -0.3);
        cabin.castShadow = true;
        carGroup.add(cabin);
        carGroup.position.set(x, 0, z);
        carGroup.rotation.y = Math.random() * Math.PI;
        scene.add(carGroup);
        cars.push(carGroup);
      }
      
      // Armas como botín
      for (let i = 0; i < 20; i++) {
        const angle = Math.random() * Math.PI*2;
        const dist = 10 + Math.random() * 55;
        const x = Math.cos(angle) * dist;
        const z = Math.sin(angle) * dist;
        const weapon = new THREE.Mesh(new THREE.BoxGeometry(0.3, 0.1, 0.8), new THREE.MeshStandardMaterial({ color: 0xffaa00, emissive: new THREE.Color(0x331100) }));
        weapon.position.set(x, 0.3, z);
        weapon.castShadow = true;
        scene.add(weapon);
        weapons.push(weapon);
      }
    }

    function setupLobby() {
      if (lobbyCharacter) scene.remove(lobbyCharacter);
      lobbyCharacter = createCharacter(0xff5500, true);
      lobbyCharacter.position.set(0, 0.2, 0);
      lobbyCharacter.rotation.y = 0;
      scene.add(lobbyCharacter);
      
      camera.position.set(0, 4.5, 6.5);
      camera.lookAt(0, 1.8, 0);
    }

    function startWaitingRoom() {
      currentState = State.WAITING;
      lobbyContainer.style.display = 'none';
      waitingContainer.style.display = 'flex';
      document.getElementById('info').style.display = 'none';
      
      const grid = document.getElementById('waiting-players');
      grid.innerHTML = '';
      for (let i = 0; i < TOTAL_PLAYERS; i++) {
        const dot = document.createElement('div');
        dot.className = 'player-dot';
        dot.textContent = i+1;
        grid.appendChild(dot);
      }
      document.getElementById('player-count').textContent = TOTAL_PLAYERS;
      
      let seconds = WAIT_SECONDS;
      document.getElementById('waiting-timer').textContent = seconds;
      
      if (countdownInterval) clearInterval(countdownInterval);
      countdownInterval = setInterval(() => {
        seconds--;
        document.getElementById('waiting-timer').textContent = seconds;
        if (seconds <= 0) {
          clearInterval(countdownInterval);
          startPlaneSequence();
        }
      }, 1000);
      
      document.getElementById('cancel-waiting').onclick = () => {
        clearInterval(countdownInterval);
        waitingContainer.style.display = 'none';
        lobbyContainer.style.display = 'flex';
        currentState = State.LOBBY;
        document.getElementById('info').style.display = 'block';
      };
    }

    function startPlaneSequence() {
      waitingContainer.style.display = 'none';
      currentState = State.PLANE;
      crosshair.style.display = 'none';
      planeIndicator.style.display = 'block';
      minimap.style.display = 'block';
      
      if (lobbyCharacter) scene.remove(lobbyCharacter);
      
      // Crear avión
      planeGroup = new THREE.Group();
      const fuse = new THREE.Mesh(new THREE.CylinderGeometry(0.8, 0.8, 6, 8), new THREE.MeshStandardMaterial({ color: 0xcccccc }));
      fuse.rotation.x = Math.PI/2;
      planeGroup.add(fuse);
      const wings = new THREE.Mesh(new THREE.BoxGeometry(5, 0.2, 1.2), new THREE.MeshStandardMaterial({ color: 0xaaaaaa }));
      wings.position.set(0, 1, 0);
      planeGroup.add(wings);
      const tail = new THREE.Mesh(new THREE.BoxGeometry(1.5, 0.8, 0.3), new THREE.MeshStandardMaterial({ color: 0x888888 }));
      tail.position.set(0, 1.5, -2.5);
      planeGroup.add(tail);
      planeGroup.position.set(-60, 55, -60);
      planeGroup.rotation.y = Math.PI/4;
      scene.add(planeGroup);
      
      localPlayer.inPlane = true;
      localPlayer.hasParachute = false;
      localPlayer.onGround = false;
      localPlayer.position.copy(planeGroup.position);
      
      camera.position.copy(planeGroup.position.clone().add(new THREE.Vector3(0, 5, 8)));
      camera.lookAt(planeGroup.position);
    }

    function jumpFromPlane() {
      if (!localPlayer.inPlane) return;
      localPlayer.inPlane = false;
      localPlayer.hasParachute = true;
      localPlayer.position.copy(planeGroup.position);
      localPlayer.velocity.set(0, -2, 0);
      planeIndicator.style.display = 'none';
      crosshair.style.display = 'block';
      currentState = State.PLAYING;
      
      if (planeGroup) scene.remove(planeGroup);
      
      // Crear jugador local en mundo
      if (playerModel) scene.remove(playerModel);
      playerModel = createCharacter(0x00aa88, true);
      playerModel.position.copy(localPlayer.position);
      scene.add(playerModel);
      
      camera.position.copy(playerModel.position.clone().add(new THREE.Vector3(0, 3, 5)));
    }

    function updateGameplay(deltaTime) {
      if (currentState === State.PLAYING && playerModel) {
        // Movimiento con WASD
        const speed = 6.5;
        moveDirection.set(0,0,0);
        if (keys.w) moveDirection.z -= 1;
        if (keys.s) moveDirection.z += 1;
        if (keys.a) moveDirection.x -= 1;
        if (keys.d) moveDirection.x += 1;
        
        if (moveDirection.length() > 0) {
          moveDirection.normalize();
          // Rotar dirección según cámara
          const forward = new THREE.Vector3(0,0,-1).applyAxisAngle(new THREE.Vector3(0,1,0), cameraYaw);
          const right = new THREE.Vector3(1,0,0).applyAxisAngle(new THREE.Vector3(0,1,0), cameraYaw);
          const dir = forward.clone().multiplyScalar(-moveDirection.z).add(right.clone().multiplyScalar(moveDirection.x));
          localPlayer.position.x += dir.x * speed * deltaTime;
          localPlayer.position.z += dir.z * speed * deltaTime;
        }
        
        // Gravedad y paracaídas
        if (!localPlayer.onGround) {
          if (localPlayer.hasParachute && localPlayer.position.y < 18) {
            localPlayer.velocity.y = -1.8;
          } else if (!localPlayer.hasParachute) {
            localPlayer.velocity.y -= 9.8 * deltaTime;
          }
          localPlayer.position.y += localPlayer.velocity.y * deltaTime;
          
          if (localPlayer.position.y <= 0.15) {
            localPlayer.position.y = 0.15;
            localPlayer.onGround = true;
            localPlayer.hasParachute = false;
            localPlayer.velocity.set(0,0,0);
          }
        }
        
        playerModel.position.copy(localPlayer.position);
        
        // Cámara tercera persona
        const camOffset = new THREE.Vector3(0, 3.5, -6).applyAxisAngle(new THREE.Vector3(0,1,0), cameraYaw);
        camera.position.lerp(playerModel.position.clone().add(camOffset), 0.2);
        camera.lookAt(playerModel.position.x, playerModel.position.y + 1.5, playerModel.position.z);
      }
      
      // Avión movimiento
      if (currentState === State.PLANE && planeGroup) {
        planeGroup.position.x += 0.8;
        planeGroup.position.z += 0.8;
        if (planeGroup.position.x > 50) planeGroup.position.x = -60;
        if (planeGroup.position.z > 50) planeGroup.position.z = -60;
        localPlayer.position.copy(planeGroup.position);
        camera.position.lerp(planeGroup.position.clone().add(new THREE.Vector3(0, 8, 12)), 0.1);
        camera.lookAt(planeGroup.position);
      }
    }

    function drawMinimap() {
      ctxMinimap.clearRect(0,0,130,130);
      ctxMinimap.fillStyle = '#2d5a27';
      ctxMinimap.beginPath();
      ctxMinimap.arc(65,65,60,0,Math.PI*2);
      ctxMinimap.fill();
      if (playerModel && currentState === State.PLAYING) {
        const px = 65 + (localPlayer.position.x / 120) * 55;
        const pz = 65 + (localPlayer.position.z / 120) * 55;
        ctxMinimap.fillStyle = 'white';
        ctxMinimap.beginPath();
        ctxMinimap.arc(px, pz, 4, 0, 2*Math.PI);
        ctxMinimap.fill();
      }
    }

    // Event Listeners
    window.addEventListener('keydown', (e) => {
      if (currentState === State.PLAYING || currentState === State.PLANE) {
        if (e.key === 'w' || e.key === 'W') keys.w = true;
        if (e.key === 'a' || e.key === 'A') keys.a = true;
        if (e.key === 's' || e.key === 'S') keys.s = true;
        if (e.key === 'd' || e.key === 'D') keys.d = true;
        if (e.key === ' ') { e.preventDefault(); keys.space = true; jumpFromPlane(); }
      }
    });
    window.addEventListener('keyup', (e) => {
      if (e.key === 'w' || e.key === 'W') keys.w = false;
      if (e.key === 'a' || e.key === 'A') keys.a = false;
      if (e.key === 's' || e.key === 'S') keys.s = false;
      if (e.key === 'd' || e.key === 'D') keys.d = false;
      if (e.key === ' ') keys.space = false;
    });
    
    document.addEventListener('mousemove', (e) => {
      if (currentState === State.PLAYING || currentState === State.PLANE) {
        cameraYaw -= e.movementX * 0.002;
        cameraPitch -= e.movementY * 0.002;
        cameraPitch = Math.max(-1.2, Math.min(0.8, cameraPitch));
      }
    });
    
    document.getElementById('start-game-btn').addEventListener('click', startWaitingRoom);
    document.getElementById('lucky-royale').addEventListener('click', ()=> alert('🎰 LUCKY ROYALE: ¡Prueba tu suerte!'));
    document.getElementById('tienda-btn').addEventListener('click', ()=> alert('🛒 TIENDA: Skins y mejoras.'));
    
    // Bloquear menú contextual
    window.addEventListener('contextmenu', e => e.preventDefault());
    
    // Animación
    function animate() {
      requestAnimationFrame(animate);
      const delta = Math.min(0.05, 0.016);
      updateGameplay(delta);
      if (currentState === State.PLAYING) drawMinimap();
      renderer.render(scene, camera);
      labelRenderer.render(scene, camera);
    }
    
    initThree();
    createWorld();
    setupLobby();
    animate();
    
    console.log('🔥 BATTLE ROYALE LOBBY - ¡Listo!');
  </script>
</body>
</html>
